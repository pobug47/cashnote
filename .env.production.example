POSTGRES_DB=cashnote
POSTGRES_USER=cashnote
POSTGRES_PASSWORD=change-this-long-random-password

# 도메인을 연결하기 전에는 :80으로 두면 외부 IP의 HTTP 접속만 사용합니다.
# 도메인을 연결한 뒤에는 예: CADDY_HOST=cashnote.example.com
CADDY_HOST=:80
PUBLIC_APP_URL=

# Google AdSense 승인 후 받은 값입니다. 비워두면 하단에 안내 배너가 표시됩니다.
AD_PROVIDER=adsense
ADSENSE_CLIENT=
ADSENSE_BOTTOM_BANNER_SLOT=
# 선택값입니다. 비워두면 ADSENSE_CLIENT의 ca-pub 값을 pub 값으로 변환해 ads.txt를 생성합니다.
ADSENSE_PUBLISHER_ID=

# 이메일 인증번호 발송 설정입니다. 인증번호 원문은 DB에 저장하지 않고 해시만 저장합니다.
AUTH_CODE_SECRET=change-this-long-random-secret
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# 쉼표로 구분한 관리자 이메일입니다. 예: admin@example.com,owner@example.com
ADMIN_EMAILS=
