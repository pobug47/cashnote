POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# 도메인을 연결하기 전에는 CADDY_HOST를 HTTP 전용 값으로 입력합니다.
# 도메인을 연결한 뒤에는 CADDY_HOST에 도메인을 입력합니다.
CADDY_HOST=
PUBLIC_APP_URL=

# Google AdSense 승인 후 받은 값을 입력합니다.
AD_PROVIDER=
ADSENSE_CLIENT=
ADSENSE_BOTTOM_BANNER_SLOT=
# 선택값입니다. 비워두면 ADSENSE_CLIENT 값을 기준으로 ads.txt를 생성합니다.
ADSENSE_PUBLISHER_ID=

# 이메일 인증번호 발송 설정입니다. 인증번호 원문은 DB에 저장하지 않고 해시만 저장합니다.
AUTH_CODE_SECRET=
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# 쉼표로 구분한 관리자 이메일입니다.
ADMIN_EMAILS=
