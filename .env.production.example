POSTGRES_DB=cashnote
POSTGRES_USER=cashnote
POSTGRES_PASSWORD=change-this-long-random-password

# 도메인을 연결하기 전에는 :80으로 두면 외부 IP의 HTTP 접속만 사용합니다.
# 도메인을 연결한 뒤에는 예: CADDY_HOST=cashnote.example.com
CADDY_HOST=:80

# Google AdSense 승인 후 받은 값입니다. 비워두면 하단에 안내 배너가 표시됩니다.
AD_PROVIDER=adsense
ADSENSE_CLIENT=
ADSENSE_BOTTOM_BANNER_SLOT=
