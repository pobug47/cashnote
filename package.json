{
  "name": "personal-finance-board",
  "version": "0.1.0",
  "private": true,
  "description": "Local personal finance, savings, investment, and dividend tracker.",
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "pwa:icons": "node scripts/generate-pwa-icons.js",
    "check": "node --check server.js && node --check src/app.js",
    "cap:sync": "cap sync android",
    "android": "cap open android",
    "android:apk:debug": "cd android && gradlew.bat assembleDebug",
    "android:apk:release": "cd android && gradlew.bat assembleRelease",
    "android:bundle": "cd android && gradlew.bat bundleRelease"
  },
  "dependencies": {
    "@capacitor/core": "^7.6.6",
    "@capacitor/filesystem": "^7.1.8",
    "@capacitor/share": "^7.0.4",
    "nodemailer": "^8.0.10",
    "pg": "^8.21.0",
    "read-excel-file": "^9.0.10",
    "write-excel-file": "^4.0.7"
  },
  "devDependencies": {
    "@capacitor/android": "^7.6.6",
    "@capacitor/cli": "^7.6.6"
  }
}
